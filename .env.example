# S3 Configuration (works with AWS S3, Cloudflare R2, MinIO, etc.)
S3_REGION=auto
S3_ENDPOINT=                    # Leave empty for AWS S3; set for R2/MinIO
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=birdcar-images
S3_FORCE_PATH_STYLE=            # Set to "true" for MinIO
CDN_BASE_URL=https://images.birdcar.dev

# Bearer token for the n8n pull endpoints (/api/leads/pending, /api/leads/:id).
# Set as a Cloudflare secret with:
#   bunx wrangler secret put WORKER_PULL_TOKEN
# Generate locally with: openssl rand -hex 32
WORKER_PULL_TOKEN=
