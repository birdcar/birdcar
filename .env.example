# Build-time secrets read by Node-side scripts (image upload, etc.).
# Worker runtime secrets (WorkOS, etc.) live in `.dev.vars` for local
# dev and as `wrangler secret put` values in prod — see
# `.dev.vars.example` and `bun run cf:bootstrap`.

# S3 Configuration (works with AWS S3, Cloudflare R2, MinIO, etc.)
S3_REGION=auto
S3_ENDPOINT=                    # Leave empty for AWS S3; set for R2/MinIO
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=birdcar-images
S3_FORCE_PATH_STYLE=            # Set to "true" for MinIO
CDN_BASE_URL=https://images.birdcar.dev
