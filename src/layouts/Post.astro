---
import Base from './Base.astro';
import TagList from '../components/TagList.astro';
import FollowBlock from '../components/FollowBlock.astro';
import type { DocumentMetadata } from '@birdcar/markdown';

interface Props {
  title: string;
  description?: string;
  image?: string;
  date: Date;
  updated?: Date;
  metadata: DocumentMetadata;
  tags?: string[];
}

const { title, description, image, date, updated, metadata, tags = [] } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${title} — birdcar`}
  description={description}
  image={image}
  type="article"
  publishedDate={date}
  modifiedDate={updated}
  tags={tags}
>
  <article class="article">
    <header class="article__header">
      <h1 class="article__title">{title}</h1>
      <div class="article__meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>{metadata.computed.readingTime} min read</span>
        <span>{metadata.computed.wordCount} words</span>
      </div>
      {tags.length > 0 && <TagList tags={tags} />}
    </header>
    <div class="prose">
      <slot />
    </div>
    <FollowBlock variant="post" />
  </article>
</Base>
