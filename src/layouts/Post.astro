---
import Base from './Base.astro';
import type { DocumentMetadata } from '@birdcar/markdown';

interface Props {
  title: string;
  date: Date;
  metadata: DocumentMetadata;
}

const { title, date, metadata } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title}>
  <article>
    <header>
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span>{metadata.computed.readingTime} min read</span>
      <span>{metadata.computed.wordCount} words</span>
    </header>
    <slot />
  </article>
</Base>
