---
import Base from './Base.astro';
import type { DocumentMetadata } from '@birdcar/markdown';

interface Props {
  title: string;
  description?: string;
  image?: string;
  date: Date;
  updated?: Date;
  metadata: DocumentMetadata;
  tags?: string[];
}

const { title, description, image, date, updated, metadata, tags = [] } = Astro.props;
const dateIso = date.toISOString().slice(0, 10);
const updatedIso = updated ? updated.toISOString().slice(0, 10) : null;
const primaryTag = tags[0];
const readingTime = metadata.computed.readingTime;
---

<Base
  title={`${title} — Birdcar`}
  description={description}
  image={image}
  type="article"
  publishedDate={date}
  modifiedDate={updated}
  tags={tags}
>
  <article class="bc-post">
    <div class="bc-prose">
      <header class="bc-post-head">
        <div class="bc-post-meta">
          <time datetime={date.toISOString()}>{dateIso}</time>
          {primaryTag && (
            <><span class="sep">·</span><a href={`/tags/${primaryTag}/`}>{primaryTag}</a></>
          )}
          {readingTime && <><span class="sep">·</span><span>{readingTime} min read</span></>}
          {updatedIso && updatedIso !== dateIso && (
            <><span class="sep">·</span><span>updated {updatedIso}</span></>
          )}
        </div>
        <h1>{title}</h1>
        {description && <p class="bc-lede">{description}</p>}
      </header>

      <slot />

      <hr class="bc-hr" />
      <p class="bc-mono-eyebrow">
        <a href="/writing/">← back to writing</a>
      </p>
    </div>
  </article>
</Base>
