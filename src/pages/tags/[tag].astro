---
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import { getPublishedPosts } from '../../lib/posts';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const tags = new Set(posts.flatMap((p) => p.allTags));
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.allTags.includes(tag)),
    },
  }));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---

<Base
  title={`#${tag} — Birdcar`}
  description={`Posts tagged with #${tag}.`}
>
  <div class="bc-page">
    <header class="bc-page-head">
      <div class="bc-mono-eyebrow">tagged · {posts.length} post{posts.length === 1 ? '' : 's'}</div>
      <h1>#{tag}</h1>
      <p class="bc-lede">
        Posts filed under <code>{tag}</code>. <a href="/writing/">All writing →</a>
      </p>
    </header>

    <ul class="bc-postlist">
      {posts.map(p => {
        const dateIso = p.data.date.toISOString().slice(0, 10);
        const primary = p.allTags[0] ?? tag;
        return (
          <li>
            <a href={`/writing/${p.id}/`} class="bc-post-row">
              <span class="bc-post-date">{dateIso}</span>
              <span class="bc-post-title">{p.data.title}</span>
              <span class="bc-post-tag">{primary}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</Base>
