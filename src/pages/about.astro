---
import Base from '../layouts/Base.astro';
import HeroDecoration from '../components/HeroDecoration.astro';
---
<Base title="About — birdcar" description="About birdcar, the developer behind this blog.">
  <section class="hero" style="position: relative;">
    <HeroDecoration />
    <p class="hero__eyebrow">about</p>
    <h1 class="hero__title" data-hero-variant="circle">Hi, I'm <em>birdcar.</em></h1>
  </section>

  <div class="about-content">
    <div class="about-profile">
      <img
        src="https://github.com/birdcar.png"
        alt="birdcar's profile photo"
        class="about-profile__image"
        width="160"
        height="160"
        loading="eager"
      />
    </div>
    <p>
      I'm a software engineer who cares about building systems that are
      well-crafted, maintainable, and thoughtful. This blog is where I write
      about the things I learn along the way.
    </p>
    <p>
      This site is built with <a href="https://astro.build">Astro</a> and
      rendered using <a href="https://github.com/birdcar/markdown-spec">Birdcar Flavored Markdown</a>,
      a superset of CommonMark with directives, extended task lists, mentions,
      hashtags, and more.
    </p>
  </div>
</Base>
