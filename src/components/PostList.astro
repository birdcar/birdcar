---
import TagList from './TagList.astro';

interface Props {
  posts: {
    id: string;
    data: {
      title: string;
      date: Date;
      description?: string;
    };
    allTags: string[];
  }[];
}

const { posts } = Astro.props;
---

<ul class="post-list">
  {posts.map((post) => (
    <li class="post-list__item">
      <div class="post-list__title">
        <a href={`/blog/${post.id}/`}>{post.data.title}</a>
      </div>
      <time class="post-list__date" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      {post.data.description && <p class="post-list__description">{post.data.description}</p>}
      {post.allTags.length > 0 && (
        <div class="post-list__tags">
          <TagList tags={post.allTags} />
        </div>
      )}
    </li>
  ))}
</ul>
