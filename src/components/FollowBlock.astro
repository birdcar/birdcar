---
interface Props {
  variant?: 'post' | 'index';
}

const { variant = 'post' } = Astro.props;

const heading = variant === 'post' ? 'One more.' : 'Stay in the loop.';
const body =
  variant === 'post'
    ? 'If this was worth your time, the next one probably will be too. No newsletter — just RSS, the way the web was meant to work.'
    : 'New post every so often. No email capture, no tracking, no "subscribe to our weekly digest." Just the feed.';
---

<aside class="follow-block" aria-labelledby="follow-block-heading">
  <p class="follow-block__eyebrow">follow</p>
  <h2 id="follow-block-heading" class="follow-block__heading">{heading}</h2>
  <p class="follow-block__body">{body}</p>
  <div class="follow-block__actions">
    <a href="/rss.xml" class="follow-block__action follow-block__action--primary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 11a9 9 0 0 1 9 9" />
        <path d="M4 4a16 16 0 0 1 16 16" />
        <circle cx="5" cy="19" r="1" />
      </svg>
      <span>RSS feed</span>
    </a>
    <a href="https://github.com/birdcar" target="_blank" rel="noopener noreferrer" class="follow-block__action">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
        <path d="M9 18c-4.51 2-5-2-7-2" />
      </svg>
      <span>GitHub</span>
    </a>
  </div>
</aside>
