---
/**
 * Subtle geometric SVG decoration for the top of the page.
 * Renders floating dots, lines, and crosses in Catppuccin accent colors,
 * spanning the full page width and fading out as it descends.
 */
---
<div class="hero-decoration" aria-hidden="true">
  <svg class="hero-decoration__svg" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMin slice">
    <!-- Scattered dots — upper region -->
    <circle cx="50" cy="40" r="3" fill="var(--ctp-mauve)" opacity="0.3" />
    <circle cx="700" cy="60" r="4" fill="var(--ctp-teal)" opacity="0.25" />
    <circle cx="200" cy="20" r="2" fill="var(--ctp-lavender)" opacity="0.3" />
    <circle cx="480" cy="35" r="3" fill="var(--ctp-pink)" opacity="0.25" />
    <circle cx="620" cy="15" r="2.5" fill="var(--ctp-peach)" opacity="0.2" />

    <!-- Mid region -->
    <circle cx="100" cy="140" r="3.5" fill="var(--ctp-blue)" opacity="0.2" />
    <circle cx="350" cy="120" r="4" fill="var(--ctp-green)" opacity="0.2" />
    <circle cx="550" cy="160" r="3" fill="var(--ctp-mauve)" opacity="0.2" />
    <circle cx="750" cy="130" r="2.5" fill="var(--ctp-teal)" opacity="0.15" />

    <!-- Lower region -->
    <circle cx="80" cy="280" r="5" fill="var(--ctp-blue)" opacity="0.15" />
    <circle cx="640" cy="300" r="3" fill="var(--ctp-pink)" opacity="0.15" />
    <circle cx="300" cy="340" r="3.5" fill="var(--ctp-peach)" opacity="0.12" />
    <circle cx="740" cy="350" r="3" fill="var(--ctp-lavender)" opacity="0.1" />
    <circle cx="150" cy="420" r="2.5" fill="var(--ctp-green)" opacity="0.1" />
    <circle cx="500" cy="450" r="3" fill="var(--ctp-mauve)" opacity="0.08" />

    <!-- Geometric lines -->
    <line x1="30" y1="100" x2="80" y2="100" stroke="var(--ctp-surface2)" stroke-width="1" opacity="0.3" />
    <line x1="680" y1="120" x2="760" y2="120" stroke="var(--ctp-surface2)" stroke-width="1" opacity="0.2" />
    <line x1="60" y1="220" x2="60" y2="270" stroke="var(--ctp-surface2)" stroke-width="1" opacity="0.2" />
    <line x1="400" y1="80" x2="450" y2="80" stroke="var(--ctp-surface2)" stroke-width="1" opacity="0.2" />
    <line x1="250" y1="200" x2="290" y2="200" stroke="var(--ctp-surface2)" stroke-width="1" opacity="0.15" />
    <line x1="600" y1="250" x2="600" y2="300" stroke="var(--ctp-surface2)" stroke-width="1" opacity="0.12" />

    <!-- Small cross marks -->
    <g opacity="0.2" stroke="var(--ctp-overlay1)" stroke-width="1">
      <line x1="720" y1="30" x2="730" y2="40" />
      <line x1="730" y1="30" x2="720" y2="40" />
    </g>
    <g opacity="0.15" stroke="var(--ctp-overlay1)" stroke-width="1">
      <line x1="30" y1="170" x2="40" y2="180" />
      <line x1="40" y1="170" x2="30" y2="180" />
    </g>
    <g opacity="0.12" stroke="var(--ctp-overlay1)" stroke-width="1">
      <line x1="450" y1="260" x2="460" y2="270" />
      <line x1="460" y1="260" x2="450" y2="270" />
    </g>
    <g opacity="0.1" stroke="var(--ctp-overlay1)" stroke-width="1">
      <line x1="200" y1="380" x2="210" y2="390" />
      <line x1="210" y1="380" x2="200" y2="390" />
    </g>
  </svg>
</div>

<style>
  .hero-decoration {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 80vh;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
    mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 30%, transparent 100%);
  }

  .hero-decoration__svg {
    width: 100%;
    height: 100%;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-decoration__svg circle {
      animation: float 6s ease-in-out infinite;
    }

    .hero-decoration__svg circle:nth-child(2n) {
      animation-delay: -2s;
      animation-duration: 8s;
    }

    .hero-decoration__svg circle:nth-child(3n) {
      animation-delay: -4s;
      animation-duration: 7s;
    }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>
